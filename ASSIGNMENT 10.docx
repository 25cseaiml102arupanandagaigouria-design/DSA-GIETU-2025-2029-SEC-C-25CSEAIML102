#include<stdio.h>
#include<stdlib.h>
#include<string.h>

struct node{
    char pname[20];
    char tname[20];
    int score;
    struct node *link;
};

struct node *start = NULL, *fresh, *ptr;

void add(){
    char pn[20], tn[20];
    int scr;

    printf("Enter the player name: ");
    scanf("%s", pn);

    printf("Enter the team name: ");
    scanf("%s", tn);

    printf("Enter the player score: ");
    scanf("%d", &scr);

    fresh = (struct node*)malloc(sizeof(struct node));

    if(fresh == NULL){
        printf("Overflow\n");
        return;
    }

    fresh->link = NULL;
    fresh->score = scr;

    strcpy(fresh->pname, pn);
    strcpy(fresh->tname, tn);

    if(start == NULL){
        start = fresh;
    }
    else{
        ptr = start;
        while(ptr->link != NULL){
            ptr = ptr->link;
        }
        ptr->link = fresh;
    }
}

void traverse(){
    if(start == NULL){
        printf("List is empty\n");
        return;
    }

    ptr = start;
    while(ptr != NULL){
        printf("%s %s %d -> ", ptr->pname, ptr->tname, ptr->score);
        ptr = ptr->link;
    }
    printf("NULL\n");
}

void check(){
    if(start == NULL){
        printf("List is empty\n");
        return;
    }

    ptr = start;
    printf("\nPlayers with score >= 50:\n");

    while(ptr != NULL){
        if(ptr->score >= 50){
            printf("%s %s %d -> ", ptr->pname, ptr->tname, ptr->score);
        }
        ptr = ptr->link;
    }
    printf("NULL\n");
}

int main(){
    int n;

    printf("Enter number of players: ");
    scanf("%d", &n);

    for(int i = 1; i <= n; i++){
        add();
    }

    printf("\nAll Players:\n");
    traverse();

    check();

    return 0;
}
